# Clinic Agency — local secret configuration
# Copy from .env.example. Fill values locally; never commit this file.

APP_ENV=development
APP_NAME=clinic-agency
APP_BASE_URL=
CONSOLE_BASE_URL=http://localhost:5173
RUNNER_HOST=127.0.0.1
RUNNER_PORT=8000
LOG_LEVEL=INFO
APP_TIMEZONE=Asia/Kolkata

# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=
WEBHOOK_SHARED_SECRET=
DATA_ENCRYPTION_KEY=

# Convex
CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_DEPLOY_KEY=

# Hosted models — OpenAI-compatible gateway/provider recommended initially
LLM_API_KEY=
LLM_BASE_URL=
MANAGER_MODEL=
COMPLIANCE_MODEL=
TRIAGE_MODEL=
KNOWLEDGE_MODEL=
DRAFTER_MODEL=
BOOKING_MODEL=
LIFECYCLE_MODEL=
LLM_JUDGE_MODEL=
MAX_CASE_COST_USD=1.00
MAX_CASE_STEPS=20
MODEL_TIMEOUT_SECONDS=45

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=

# Google Calendar OAuth / dedicated service account
# Prefer a service account and share only the dedicated demo/operations calendar with it.
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_CALENDAR_HOLD_MINUTES=15
GOOGLE_CALENDAR_SLOT_MINUTES=30
GOOGLE_CALENDAR_BUFFER_BEFORE_MINUTES=0
GOOGLE_CALENDAR_BUFFER_AFTER_MINUTES=10

# Dodo Payments — use test mode until production acceptance is complete
DODO_API_KEY=
DODO_WEBHOOK_SECRET=
DODO_ENVIRONMENT=test_mode
DODO_PRODUCT_ID=
DODO_CURRENCY=INR
DODO_DEPOSIT_PERCENT=20
DODO_SUCCESS_URL=
DODO_CANCEL_URL=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL_ID=
ELEVENLABS_TTS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=

# Linkup
LINKUP_API_KEY=
LINKUP_ALLOWED_DOMAINS=clearskin.in,hairmdindia.com
LINKUP_TIMEOUT_SECONDS=15

# Cloudflare Pages / Worker
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PAGES_PROJECT_NAME=clinic-agency-console
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_WORKER_NAME=clinic-agency-ingress
CLOUDFLARE_CONSOLE_DOMAIN=
CLOUDFLARE_API_DOMAIN=

# Google Cloud Run (recommended FastAPI host)
GCP_PROJECT_ID=
GCP_REGION=asia-south1
GCP_CLOUD_RUN_SERVICE=clinic-agency-runner
GCP_ARTIFACT_REGISTRY=clinic-agency
GCP_SERVICE_ACCOUNT_EMAIL=

# Optional WhatsApp Cloud API
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Safety / retention
STORE_RAW_AUDIO=false
MESSAGE_RETENTION_DAYS=30
TRACE_PAYLOAD_MODE=redacted
RED_FLAG_ESCALATION_CONTACT=
