# Clinic Agency — local secret configuration
# Copy from .env.example. Fill values locally; never commit this file.

APP_ENV=development
APP_NAME=clinic-agency
APP_BASE_URL=
CONSOLE_BASE_URL=http://localhost:5173
RUNNER_HOST=127.0.0.1
RUNNER_PORT=8000
LOG_LEVEL=INFO
APP_TIMEZONE=Asia/Kolkata

# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=
WEBHOOK_SHARED_SECRET=
DATA_ENCRYPTION_KEY=

# Convex — business state only
CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_DEPLOY_KEY=

# Langfuse — traces, prompts, datasets, experiments, and scores
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Required: use https://cloud.langfuse.com (EU), https://us.cloud.langfuse.com (US), or self-host.
LANGFUSE_HOST=

# Hosted models — OpenAI-compatible gateway/provider recommended initially
# Runtime uses MODEL_* consistently (LLM_* legacy names are not read).
MODEL_API_KEY=
MODEL_BASE_URL=
MODEL_TIMEOUT_SECONDS=30
MODEL_MAX_RETRIES=0
TELEGRAM_REPLY_MODEL=
TELEGRAM_REPLY_PROMPT_NAME=roles/telegram-reply
TELEGRAM_REPLY_PROMPT_LABEL=production
TELEGRAM_REPLY_MAX_COST_USD=0.25
# USD per million input/output tokens; set to the selected provider's published prices.
TELEGRAM_REPLY_INPUT_PRICE_PER_MILLION=1.00
TELEGRAM_REPLY_OUTPUT_PRICE_PER_MILLION=4.00

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=

# Google Calendar OAuth / dedicated service account
# Prefer a service account and share only the dedicated demo/operations calendar with it.
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_CALENDAR_HOLD_MINUTES=15
GOOGLE_CALENDAR_SLOT_MINUTES=30
GOOGLE_CALENDAR_BUFFER_BEFORE_MINUTES=0
GOOGLE_CALENDAR_BUFFER_AFTER_MINUTES=10

# Dodo Payments — use test mode until production acceptance is complete
DODO_API_KEY=
DODO_WEBHOOK_SECRET=
DODO_ENVIRONMENT=test_mode
DODO_PRODUCT_ID=
DODO_CURRENCY=INR
DODO_DEPOSIT_PERCENT=20
DODO_SUCCESS_URL=
DODO_CANCEL_URL=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL_ID=
ELEVENLABS_TTS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=

# Linkup
LINKUP_API_KEY=
LINKUP_ALLOWED_DOMAINS=clearskin.in,hairmdindia.com
LINKUP_TIMEOUT_SECONDS=15

# Cloudflare Pages / Worker
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PAGES_PROJECT_NAME=clinic-agency-console
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_WORKER_NAME=clinic-agency-ingress
CLOUDFLARE_CONSOLE_DOMAIN=
CLOUDFLARE_API_DOMAIN=

# Google Cloud Run (recommended FastAPI host)
GCP_PROJECT_ID=
GCP_REGION=asia-south1
GCP_CLOUD_RUN_SERVICE=clinic-agency-runner
GCP_ARTIFACT_REGISTRY=clinic-agency
GCP_SERVICE_ACCOUNT_EMAIL=

# Optional WhatsApp Cloud API
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Safety / retention
STORE_RAW_AUDIO=false
MESSAGE_RETENTION_DAYS=30
TRACE_PAYLOAD_MODE=redacted
RED_FLAG_ESCALATION_CONTACT=
